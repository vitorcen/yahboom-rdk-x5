[Unit]
Description=rosbridge websocket bridge (ws://:9090)
After=network.target

[Service]
Environment=HOME=/root ROS_LOG_DIR=/tmp/roslog ROS_DOMAIN_ID=99
ExecStartPre=/bin/mkdir -p /tmp/roslog
ExecStart=/bin/bash -c "source /opt/tros/humble/setup.bash; exec ros2 launch rosbridge_server rosbridge_websocket_launch.xml"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
