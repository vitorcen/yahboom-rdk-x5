[Unit]
Description=Follow-me: BPU perception chain + follow node (OK lock / Palm stop)
# Camera moved from mipi-cam (retired) to the USB Astra (astra-cam). NOTE:
# follow-me's BPU chain still wants /image_raw and IMX219 geometry, so it needs
# repointing to the Astra color before it works again — tracked separately.
After=nav-bringup.service ms200-lidar.service
Wants=nav-bringup.service ms200-lidar.service
# Never give up retrying: at boot the camera/BPU may not be ready yet and the
# chain dies fast — the default 5-tries-in-10s burst limit then parked the
# unit as failed, which is why the GUI switch showed OFF after a reboot.
StartLimitIntervalSec=0

[Service]
Type=simple
# ROS logging needs a resolvable HOME / log dir; a bare systemd env has neither
Environment=HOME=/root
Environment=ROS_LOG_DIR=/tmp/roslog
ExecStartPre=/bin/mkdir -p /tmp/roslog
ExecStart=/home/sunrise/follow/follow_start.sh
Restart=always
RestartSec=5
KillMode=mixed
# The perception chain needs >10 s to wind down; 10 s used to end in SIGKILL
# and a spurious failed/timeout state.
TimeoutStopSec=25

[Install]
WantedBy=multi-user.target
